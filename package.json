{
  "name": "neuron-dsl",
  "version": "1.0.1",
  "description": "AI-first declarative web app DSL compiler",
  "type": "module",
  "bin": {
    "neuron": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git@github-second:rayforvideos/neuron.git"
  },
  "keywords": [
    "neuron",
    "dsl",
    "compiler",
    "spa",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
